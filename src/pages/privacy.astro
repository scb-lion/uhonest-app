---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import head from '../partials/privacy.head.html?raw';
import content from '../partials/privacy.body.html?raw';

const title = `Privacy Policy | UHonest`;
const description = `Last updated: April 10, 2017`;
const bodyClass = `privacy-policy page-template-default page page-id-3  wp-embed-responsive oxygen-body`;
---
<BaseLayout title={title} description={description} bodyClass={bodyClass}>
  <Fragment slot="head" set:html={head} />
  <Header />
  <Fragment set:html={content} />
  <Footer />
</BaseLayout>
