---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import head from '../partials/contact.head.html?raw';
import content from '../partials/contact.body.html?raw';

const title = `Contact | UHonest`;
const description = `If you're looking to get in touch with UHonest, you can reach us here.`;
const bodyClass = `page-template-default page page-id-22  wp-embed-responsive oxygen-body`;
---
<BaseLayout title={title} description={description} bodyClass={bodyClass}>
  <Fragment slot="head" set:html={head} />
  <Header />
  <Fragment set:html={content} />
  <Footer />
</BaseLayout>
