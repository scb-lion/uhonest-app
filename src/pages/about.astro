---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import head from '../partials/about.head.html?raw';
import content from '../partials/about.body.html?raw';

const title = `About | UHonest`;
const description = `Want to learn more about UHonest? Read more about us here.`;
const bodyClass = `page-template-default page page-id-20  wp-embed-responsive oxygen-body`;
---
<BaseLayout title={title} description={description} bodyClass={bodyClass} image="/og-about.png">
  <Fragment slot="head" set:html={head} />
  <Header />
  <Fragment set:html={content} />
  <Footer />
</BaseLayout>
