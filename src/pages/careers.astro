---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import head from '../partials/careers.head.html?raw';
import content from '../partials/careers.body.html?raw';

const title = `Careers | UHonest`;
const description = `Looking for something new in your career? Check out our latest job openings at UHonest.`;
const bodyClass = `page-template-default page page-id-87  wp-embed-responsive oxygen-body`;
---
<BaseLayout title={title} description={description} bodyClass={bodyClass}>
  <Fragment slot="head" set:html={head} />
  <Header />
  <Fragment set:html={content} />
  <Footer />
</BaseLayout>
